# TrendoAI environment variables example
# Copy this file to .env and fill in real values locally or in Render.

# Google AI Studio API keys
GEMINI_API_KEY=your_google_ai_studio_key
GEMINI_API_KEY2=
GEMINI_API_KEY3=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_MODEL_BACKUP=gemini-2.5-flash-lite

# Telegram
TELEGRAM_BOT_TOKEN=your_botfather_token
TELEGRAM_CHANNEL_ID=@your_channel_or_numeric_id
TELEGRAM_ADMIN_ID=your_telegram_user_id

# Unsplash
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Admin panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# Flask/security
SECRET_KEY=change_this_to_a_long_random_value
CRON_SECRET=change_this_to_a_long_random_value

# Site/deploy
SITE_URL=https://trendoai.uz
FLASK_ENV=production

# Analytics and remarketing
GA4_ID=
GOOGLE_ADS_ID=
FACEBOOK_PIXEL_ID=

# Database examples
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_URL=mysql://user:password@host:3306/dbname
